# ─────────────────────────────────────────────────────────────────────────────
# Short Publisher — Environment Variables
#
# There are 3 places where variables live. Read carefully.
#
#  1. VERCEL ENV VARS   → Vercel dashboard → Project → Settings → Environment Variables
#  2. GITHUB SECRETS    → Your repo on GitHub → Settings → Secrets and variables → Actions
#  3. APP SECRETS       → Your deployed app → /dashboard/secrets (stored in NeonDB)
#
# ─────────────────────────────────────────────────────────────────────────────


# ── 1. VERCEL ENV VARS (add all 4 before first deploy) ───────────────────────
#
#  These are needed for the app to start. They cannot be stored in the
#  dashboard because the dashboard itself depends on them to boot.

# NeonDB connection string — the only database credential needed
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Shared secret between Vercel and GitHub Actions.
# GitHub Actions sends this in every API request so the dashboard can verify it.
PIPELINE_SECRET_KEY=generate-a-random-32-char-string-here

# Admin dashboard login password (used at /login)
DASHBOARD_PASSWORD=change-me-to-something-strong

# Random hex string for session cookie signing.
# Generate with: openssl rand -hex 32
AUTH_TOKEN=generate-a-random-64-char-hex-string-here


# ── 2. GITHUB SECRETS (add to repo → Settings → Secrets and variables → Actions) ──
#
#  These are the ONLY secrets GitHub Actions needs.
#  All API keys are loaded from the app database at runtime — GitHub never sees them.

# Your Vercel deployment URL (pipeline uses this to call the dashboard API)
APP_URL=https://your-app.vercel.app

# Same value as PIPELINE_SECRET_KEY above — must match exactly
# PIPELINE_SECRET_KEY=  (already listed above — set the same value in GitHub)


# ── 3. APP SECRETS (enter at /dashboard/secrets after deploying) ──────────────
#
#  Do NOT add these to Vercel or GitHub. Enter them in the deployed app at:
#  https://your-app.vercel.app/dashboard/secrets
#
#  They are stored in NeonDB and fetched by the pipeline automatically at runtime.
#  Listed here (commented out) only as a reference for local development overrides.

# ANTHROPIC_API_KEY=          # Claude AI — script generation
# ELEVENLABS_API_KEY=         # ElevenLabs — text-to-speech voiceover
# ELEVENLABS_VOICE_ID=        # ElevenLabs — which voice to use (ID from voice URL)
# FAL_KEY=                    # fal.ai — Kling 2.6 Pro video clip generation

# R2_ACCOUNT_ID=              # Cloudflare — your account ID (top-right of dashboard)
# R2_ACCESS_KEY_ID=           # Cloudflare R2 — API token access key
# R2_SECRET_ACCESS_KEY=       # Cloudflare R2 — API token secret key
# R2_BUCKET_NAME=             # Cloudflare R2 — bucket name (e.g. short-publisher-videos)
# R2_PUBLIC_URL=              # Cloudflare R2 — public CDN URL (e.g. https://pub-xxx.r2.dev)

# YOUTUBE_CLIENT_ID=          # Google Cloud — OAuth 2.0 client ID
# YOUTUBE_CLIENT_SECRET=      # Google Cloud — OAuth 2.0 client secret
# YOUTUBE_REFRESH_TOKEN=      # YouTube — long-lived refresh token (from get_youtube_token.py)

# TELEGRAM_BOT_TOKEN=         # Telegram — bot token from @BotFather (optional)
# TELEGRAM_CHAT_ID=           # Telegram — your numeric chat ID (optional)

# RESEND_API_KEY=             # Resend — email notification API key (optional)
# RESEND_FROM_EMAIL=          # Resend — verified sender address (optional)
# CONTACT_NOTIFICATION_EMAIL= # Where to receive pipeline email alerts (optional)

# GH_TOKEN=                   # GitHub PAT — needed to trigger/view pipeline from dashboard
# GH_REPO=                    # GitHub — your repo in format: username/repo-name
# GH_WORKFLOW_FILE=           # GitHub — workflow filename, e.g. publish.yml

# APP_URL=                    # Your Vercel URL — also store here so email templates can use it
# BACKGROUND_MUSIC_URL=       # Direct MP3 URL played at 12% volume under voiceover (optional)
