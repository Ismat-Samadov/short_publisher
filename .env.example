# ─────────────────────────────────────────────────────────────
# Short Publisher — Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# Database (NeonDB)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ── AI Services ───────────────────────────────────────────────

# Script generation — Claude claude-sonnet-4-6
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Voiceover — ElevenLabs (premium quality, word timestamps)
# https://elevenlabs.io/
ELEVENLABS_API_KEY=
# Voice ID — find yours at elevenlabs.io/voice-library
# Default: Adam (natural, authoritative). Alternatives: Rachel, Domi, Bella
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Cinematic video clips — Kling 2.5 Pro via fal.ai
# https://fal.ai/ — create API key in dashboard
# ~$0.29 per 10s clip, ~$2-4 per Short depending on length
FAL_KEY=

# ── Storage ───────────────────────────────────────────────────

# Cloudflare R2 (video archive + backup)
# Create R2 bucket + API token in Cloudflare dashboard
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=short-publisher
# Your R2 public URL (enable "Public Access" on the bucket)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── YouTube ───────────────────────────────────────────────────

# YouTube Data API v3 OAuth2 credentials
# 1. Create project in Google Cloud Console
# 2. Enable YouTube Data API v3
# 3. Create OAuth2 credentials (Desktop app)
# 4. Run: python scripts/get_youtube_token.py to get refresh token
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Notifications ─────────────────────────────────────────────

# Telegram Bot (success/failure alerts)
# 1. Create bot via @BotFather
# 2. Get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=your-random-secret

# ── GitHub (for pipeline dashboard) ──────────────────────────

# Personal Access Token with: repo + actions:read + workflow scopes
GH_TOKEN=ghp_...
GH_REPO=your-username/short-publisher
GH_WORKFLOW_FILE=publish.yml

# ── App ───────────────────────────────────────────────────────

APP_URL=https://your-app.vercel.app
# Random secret — GitHub Actions sends this to authenticate pipeline API calls
PIPELINE_SECRET_KEY=generate-a-random-32-char-string-here
NEXT_PUBLIC_APP_NAME=Short Publisher

# ── Dashboard Auth ────────────────────────────────────────────

# Password to log into the admin dashboard
DASHBOARD_PASSWORD=change-me
# A random string used as the session token stored in the auth cookie
# Generate with: openssl rand -hex 32
AUTH_TOKEN=generate-a-random-64-char-hex-string-here

# ── Optional ──────────────────────────────────────────────────

# Background music (royalty-free MP3 URL, played at 12% volume)
# Find free tracks at: pixabay.com/music or freemusicarchive.org
# Leave empty to use voice-only output
BACKGROUND_MUSIC_URL=
