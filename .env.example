# ─────────────────────────────────────────────────────────────────────────────
# Short Publisher — Minimal Required Environment Variables
#
# All other API keys (Anthropic, ElevenLabs, YouTube, Telegram, Resend, etc.)
# are managed from the admin dashboard at /dashboard/secrets and stored in DB.
# You do NOT need to add them here or to GitHub Actions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Vercel needs these 4 ─────────────────────────────────────────────────────

# NeonDB connection string — the only database credential needed
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Pipeline authentication — GitHub Actions sends this to verify API requests
PIPELINE_SECRET_KEY=generate-a-random-32-char-string-here

# Dashboard login password
DASHBOARD_PASSWORD=change-me-to-something-strong

# Random hex string for session cookie signing — generate with: openssl rand -hex 32
AUTH_TOKEN=generate-a-random-64-char-hex-string-here

# ── GitHub Actions needs these 2 ─────────────────────────────────────────────

# Your Vercel deployment URL (pipeline uses this to call the dashboard API)
APP_URL=https://your-app.vercel.app

# Same PIPELINE_SECRET_KEY as above
# PIPELINE_SECRET_KEY=  (already listed above)

# ── Optional (local dev overrides) ───────────────────────────────────────────

# These override any values stored in the dashboard DB.
# Useful for local development — leave empty in production.

# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# FAL_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# CONTACT_NOTIFICATION_EMAIL=
# GH_TOKEN=
# GH_REPO=
# GH_WORKFLOW_FILE=
# BACKGROUND_MUSIC_URL=
# NEXT_PUBLIC_APP_NAME=Short Publisher
